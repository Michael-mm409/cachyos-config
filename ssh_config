# --- GitHub (The Source of Truth) ---
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_desktop

# --- The Brain (Mini-PC / Proxmox) ---
# Supports: ssh brain OR ssh pve
Host brain pve
    HostName 192.168.8.10
    User michael
    IdentityFile ~/.ssh/id_ed25519_desktop

# --- The Laptop ---
Host laptop
    HostName 192.168.8.X  # <-- Make sure to swap X with the real IP
    User michael
    IdentityFile ~/.ssh/id_ed25519_desktop

# --- The Desktop ---
Host desktop
    HostName 192.168.8.Y  # <-- Make sure to swap Y with the real IP
    User michael
    IdentityFile ~/.ssh/id_ed25519_desktop

# --- Global Settings (The Safety Net) ---
Host *
    AddKeysToAgent yes
    IdentitiesOnly yes
    IdentityFile ~/.ssh/id_ed25519_desktop
    ServerAliveInterval 60
    ServerAliveCountMax 3
